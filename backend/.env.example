# Server
APP_NAME=Dysarthria Voice Backend
APP_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Local STT model
STT_BASE_MODEL=facebook/wav2vec2-base-960h
STT_ADAPTER_PATH=models/wav2vec2-torgo-standard-lora
STT_SAMPLE_RATE=16000
DEVICE=auto

# Claude
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Deepgram Aura TTS
DEEPGRAM_API_KEY=your_deepgram_key_here
DEEPGRAM_AURA_MODEL=aura-2-thalia-en
DEEPGRAM_ENCODING=mp3
DEEPGRAM_CONTAINER=
DEEPGRAM_SAMPLE_RATE=22050

# Fetch.ai / Agentverse
FETCHAI_AGENTVERSE_API_KEY=your_fetch_ai_agentverse_key_here
AGENTVERSE_API_KEY=your_fetch_ai_agentverse_key_here
AGENTVERSE_SEARCH_URL=https://agentverse.ai/v1/search/agents
AGENTVERSE_TIMEOUT_SECONDS=10
AGENTVERSE_PROTOCOL_DIGEST=

MAX_TTS_CHARS=2000